# WashBoard — variables d'environnement
# Copier en .env.local et renseigner les valeurs. NE JAMAIS committer .env.local.

# ── Supabase ───────────────────────────────────────────────────────────────
# URL et clés du projet Supabase (Dashboard Supabase → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service_role (SECRET, jamais exposée au client — usage serveur uniquement)
SUPABASE_SERVICE_ROLE_KEY=

# ── Application ────────────────────────────────────────────────────────────
# URL publique de l'app (ex. http://localhost:3000 en local, https://washboard.fr en prod)
NEXT_PUBLIC_APP_URL=

# ── Emails (Resend) ────────────────────────────────────────────────────────
# Clé API Resend (envoi des emails : réservation, reçu, avis Google...)
RESEND_API_KEY=

# ── Google Maps (zones, distances, frais de déplacement) ───────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Google Calendar (OAuth — synchro agenda du laveur) ─────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URL de callback OAuth (ex. https://washboard.fr/api/auth/google-calendar/callback)
GOOGLE_REDIRECT_URI=
# Clé du compte de service Google (JSON), si utilisé pour l'accès agenda
GOOGLE_SERVICE_ACCOUNT_KEY=

# ── Cron (tâches planifiées : purge comptes, envoi des avis) ───────────────
# Secret partagé pour protéger les routes /api/cron/* (Vercel Cron / cron-job.org)
CRON_SECRET=
